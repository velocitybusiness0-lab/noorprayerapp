<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
  <application>
    <service
      android:name="expo.modules.appblocker.AppBlockerAccessibilityService"
      android:exported="false"
      android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
      <intent-filter>
        <action android:name="android.accessibilityservice.AccessibilityService" />
      </intent-filter>
      <meta-data
        android:name="android.accessibilityservice"
        android:resource="@xml/app_blocker_accessibility_config" />
    </service>

    <activity
      android:name="expo.modules.appblocker.PrayerBlockActivity"
      android:exported="false"
      android:excludeFromRecents="true"
      android:launchMode="singleInstance"
      android:showOnLockScreen="true"
      android:taskAffinity="expo.modules.appblocker.prayerblock"
      android:theme="@style/Theme.AppBlocker.PrayerBlock" />
  </application>
</manifest>
